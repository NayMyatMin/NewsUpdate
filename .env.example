# ============================================================
# LLM Provider: "anthropic" or "openai"
# ============================================================
LLM_PROVIDER=openai

# --- Anthropic (if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- OpenAI (if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini
# For OpenAI-compatible APIs (Azure, vLLM, Ollama, etc.), set base URL:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment

# ============================================================
# Two-tier LLM filtering (L1 cheap + L2 deep)
# L1 uses the model above for fast screening
# L2 uses a stronger model for final ranking
# ============================================================
L2_ENABLED=true
L2_OPENAI_MODEL=gpt-4o
L2_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================================
# Embedding model for cross-lingual deduplication
# Uses OpenAI embeddings API (works with OPENAI_API_KEY above)
# ============================================================
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Optional news sources
# ============================================================
NEWSAPI_KEY=

# RSSHub instance URL (public or self-hosted)
RSSHUB_BASE_URL=https://rsshub.rssforever.com
